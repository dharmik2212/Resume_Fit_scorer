# ── LLM Provider (Hugging Face) ───────────────────────
# Get your token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# Custom API URL if default is blocked (e.g. reverse proxy)
# HF_API_URL=
# Proxy for HF API calls (e.g. http://127.0.0.1:7890)
# HF_API_PROXY=

# ── Embedding Mode ────────────────────────────────────
# Offline TF-IDF is the default. Enable only if the model is installed/cached locally.
USE_TRANSFORMER_EMBEDDINGS=false
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Dynamic Thresholds ────────────────────────────────
# When enabled, uses percentile-based filtering instead of absolute cutoffs.
USE_DYNAMIC_THRESHOLDS=true
STAGE1_KEEP_PERCENT=60
STAGE2_KEEP_COUNT=15

# Absolute thresholds (used only when USE_DYNAMIC_THRESHOLDS=false)
BM25_THRESHOLD=25
SEMANTIC_THRESHOLD=0.12

# Final stage cap
TOP_N_FOR_LLM=10
MAX_RESUMES=50
